APP_ENV=production
APP_URL=https://head-heart.atomglobal.com
APP_KEY=base64:generate-a-random-32-byte-key
APP_DEBUG=false
APP_TIMEZONE=Asia/Singapore
TRUSTED_PROXY_COUNT=1

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=head_heart_v2
DB_USERNAME=head_heart_v2
DB_PASSWORD=

SESSION_COOKIE=hhaa_admin
SESSION_LIFETIME=7200
SESSION_SAME_SITE=Strict
SESSION_SECURE=true
REPORT_TOKEN_LIFETIME_DAYS=30
RESUME_TOKEN_LIFETIME_HOURS=168

STRIPE_MODE=test
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PERSONAL=
STRIPE_PRICE_NEWJOINER=
STRIPE_PRICE_MANAGER=
STRIPE_PRICE_EXECUTIVE=

MAIL_PROVIDER=smtp2go
MAIL_FROM_ADDRESS=assessment@atomglobal.com
MAIL_FROM_NAME=Atom Global Consulting
MAIL_REPLY_TO=
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
SMTP2GO_API_KEY=
SMTP2GO_API_URL=https://api.smtp2go.com/v3/email/send
ADMIN_ALERT_EMAILS=

TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
CRON_TOKEN=

STORAGE_PATH=/var/lib/head-heart-alignment
MEDIA_PUBLIC_PREFIX=/media-uploads
MAX_UPLOAD_BYTES=10485760
ALLOWED_IMAGE_MIME=image/jpeg,image/png,image/webp,image/avif,image/svg+xml

VITE_API_MODE=production
VITE_API_BASE_URL=/api
VITE_ENABLE_SW=true
